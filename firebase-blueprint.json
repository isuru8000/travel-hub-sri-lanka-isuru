{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID from Firebase Auth." },
        "name": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photo": { "type": "string", "description": "URL to the user's profile photo." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role." },
        "createdAt": { "type": "timestamp", "description": "When the user profile was created." }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Memory": {
      "title": "Memory",
      "description": "A travel memory shared by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique memory ID." },
        "authorUid": { "type": "string", "description": "The UID of the user who created the memory." },
        "userName": { "type": "string", "description": "The name of the user who created the memory." },
        "userPhoto": { "type": "string", "description": "The photo of the user who created the memory." },
        "locationEN": { "type": "string", "description": "Location in English." },
        "locationSI": { "type": "string", "description": "Location in Sinhala." },
        "titleEN": { "type": "string", "description": "Title in English." },
        "titleSI": { "type": "string", "description": "Title in Sinhala." },
        "storyEN": { "type": "string", "description": "Story in English." },
        "storySI": { "type": "string", "description": "Story in Sinhala." },
        "image": { "type": "string", "description": "Image URL or base64 data." },
        "likes": { "type": "number", "description": "Number of likes." },
        "rating": { "type": "number", "description": "Rating out of 5." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags for the memory." },
        "createdAt": { "type": "timestamp", "description": "When the memory was created." }
      },
      "required": ["id", "authorUid", "userName", "locationEN", "locationSI", "titleEN", "titleSI", "storyEN", "storySI", "likes", "rating", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a memory.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique comment ID." },
        "memoryId": { "type": "string", "description": "The ID of the memory this comment belongs to." },
        "authorUid": { "type": "string", "description": "The UID of the user who created the comment." },
        "userName": { "type": "string", "description": "The name of the user who created the comment." },
        "userPhoto": { "type": "string", "description": "The photo of the user who created the comment." },
        "textEN": { "type": "string", "description": "Comment text in English." },
        "textSI": { "type": "string", "description": "Comment text in Sinhala." },
        "createdAt": { "type": "timestamp", "description": "When the comment was created." }
      },
      "required": ["id", "memoryId", "authorUid", "userName", "textEN", "textSI", "createdAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A user's favorite destination.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user." },
        "destinationId": { "type": "string", "description": "The ID of the destination." },
        "createdAt": { "type": "timestamp", "description": "When the favorite was added." }
      },
      "required": ["userId", "destinationId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "memories/{memoryId}": {
      "schema": { "$ref": "#/entities/Memory" },
      "description": "Stores travel memories."
    },
    "memories/{memoryId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Stores comments on a memory."
    },
    "favorites/{favoriteId}": {
      "schema": { "$ref": "#/entities/Favorite" },
      "description": "Stores user favorite destinations. ID is usually userId_destinationId."
    }
  }
}
